      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npm update:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm info:*)",
      "Bash(npm view:*)",
      "Bash(npm list:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm pack:*)",
      "Bash(npx tsc:*)",
      "Bash(npx tsx:*)",
      "Bash(npx eslint:*)",
      "Bash(npx next:*)",
      "Bash(node:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(tr:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(pkill:*)",
